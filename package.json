{
  "name": "@saroj-parajuli/spsdesign",
  "version": "0.1.0",
  "description": "Shared SPS design system package with MUI exports, theme helpers, animations, and Sass assets.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saroj-parajuli/design.git"
  },
  "homepage": "https://github.com/saroj-parajuli/design#readme",
  "bugs": {
    "url": "https://github.com/saroj-parajuli/design/issues"
  },
  "keywords": [
    "design-system",
    "mui",
    "react",
    "sass",
    "theme",
    "sps"
  ],
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.scss"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mui": {
      "types": "./dist/mui/index.d.ts",
      "import": "./dist/mui/index.js",
      "require": "./dist/mui/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./animations": {
      "types": "./dist/animations/index.d.ts",
      "import": "./dist/animations/index.js",
      "require": "./dist/animations/index.cjs"
    },
    "./sass": "./dist/sass/index.scss",
    "./sass/*": "./dist/sass/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup && cp -R src/sass dist/sass",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "typescript": "^5.8.2",
    "tsup": "^8.5.0"
  }
}